# ============================================================
# LLM-QAuto 环境变量配置
# 复制此文件为 .env 并填入你的API密钥
# ============================================================

# ============================================================
# 火山引擎 (ByteDance / Volcano Engine) - 推荐，有免费额度
# 模型: Doubao-Seed-2.0-Code
# 文档: https://www.volcengine.com/docs/82379
# ============================================================

# 火山引擎API密钥
ARK_API_KEY=1a468d05-7728-449f-9384-9c600d4372a2

# 火山引擎模型ID (Doubao-Seed-2.0-Code)
ARK_MODEL_ID=doubao-seed-2.0-code

# 火山引擎推理点ID (需要在控制台创建)
# 访问: https://console.volcengine.com/ark/ 创建推理点
ARK_ENDPOINT_ID=your-endpoint-id

# 火山引擎基础URL (一般不需要修改)
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3


# ============================================================
# OpenAI - 备用选项
# 官网: https://platform.openai.com
# ============================================================

# OpenAI API密钥 (可选)
# OPENAI_API_KEY=sk-your-openai-key-here

# OpenAI模型 (可选)
# OPENAI_MODEL=gpt-4o-mini


# ============================================================
# 其他国内厂商API (可选)
# ============================================================

# 阿里云百炼
# ALIYUN_API_KEY=your-aliyun-key
# ALIYUN_MODEL=qwen-max

# 智谱AI
# ZHIPU_API_KEY=your-zhipu-key
# ZHIPU_MODEL=glm-4

# 百度云 VOD 多模态大模型（Gemini generateContent）
# 文档: https://cloud.baidu.com/doc/VOD/s/Lmldou5mj
# API Key 鉴权（v3）:
# LLM_PROVIDER=baidu_vod
# BAIDU_VOD_API_KEY=bce-v3/ALTAK-xxx/xxx
# BAIDU_VOD_MODEL=G3FP
# BAIDU_VOD_BASE_URL=https://vod.bj.baidubce.com/v3/chat/gc
# BAIDU_VOD_AUTH_MODE=apikey
# 可选：思考模式 LOW / MEDIUM / HIGH（G3FP 还支持 MINIMAL）
# BAIDU_VOD_THINKING_LEVEL=MEDIUM
# BAIDU_VOD_INCLUDE_THOUGHTS=false

# AK/SK 鉴权（v2，需控制台 AccessKey）:
# BAIDU_VOD_AUTH_MODE=aksk
# BAIDU_ACCESS_KEY_ID=your-access-key-id
# BAIDU_SECRET_ACCESS_KEY=your-secret-access-key
# BAIDU_VOD_BASE_URL=https://vod.bj.baidubce.com/v2/chat/gc


# ============================================================
# 代理设置 (如果需要)
# ============================================================

# HTTP代理
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890


# ============================================================
# 平台配置
# ============================================================

# Web界面端口
WEB_PORT=8080

# 是否启用调试模式
DEBUG=false
